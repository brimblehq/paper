{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Brimble",
  "description": "Brimble documentation. Deploy applications, manage domains, scale services, and ship without operating infrastructure.",
  "colors": {
    "primary": "#006fff",
    "light": "#006fff",
    "dark": "#006fff"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#1a1c1e"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity"]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Brimble Docs",
      "og:image": "https://brimble.io/og-image.png",
      "twitter:card": "summary_large_image",
      "twitter:site": "@brimblehq",
      "twitter:creator": "@brimblehq",
      "robots": "index, follow"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "favicon": "/logo/icon.png",
  "logo": {
    "light": "/logo/icon.png",
    "dark": "/logo/icon.png"
  },
  "fonts": {
    "heading": {
      "family": "ABC Marfa",
      "source": "/fonts/ABCMarfaVariableVF-Trial.woff2",
      "format": "woff2",
      "weight": 700
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started/introduction",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Projects",
            "icon": "cube",
            "pages": [
              "projects/overview",
              "projects/service-types",
              "projects/frameworks",
              "projects/regions",
              "projects/builds",
              "projects/build-system",
              "projects/deployments",
              "projects/git-integrations",
              "projects/deploy-a-worker",
              "projects/deploy-a-database",
              "projects/deploy-an-mcp-server",
              "projects/deploy-from-docker-image",
              "projects/discover-mcp-servers",
              "projects/persistent-disk",
              "projects/rollback-a-deployment",
              "projects/password-protect"
            ]
          },
          {
            "group": "Sandboxes",
            "icon": "box",
            "pages": [
              "sandboxes/overview",
              "sandboxes/sdks",
              "sandboxes/quickstart",
              "sandboxes/snapshots",
              "sandboxes/sandbox-system",
              {
                "group": "Cookbook",
                "icon": "utensils",
                "pages": [
                  "sandboxes/cookbook/untrusted-code",
                  "sandboxes/cookbook/ai-coding-agent",
                  "sandboxes/cookbook/persistent-dev-env"
                ]
              }
            ]
          },
          {
            "group": "Volumes",
            "icon": "hard-drive",
            "pages": ["volumes/overview"]
          },
          {
            "group": "Domains",
            "icon": "globe",
            "pages": [
              "domains/custom-domains",
              "domains/buy-a-domain",
              "domains/transfer-a-domain",
              "domains/manage-dns-records",
              "domains/redirect-a-domain",
              "domains/dns-records"
            ]
          },
          {
            "group": "Environments",
            "icon": "layer-group",
            "pages": [
              "environments/overview",
              "environments/environment-variables",
              "environments/env-references"
            ]
          },
          {
            "group": "Networking",
            "icon": "network-wired",
            "pages": [
              "networking/overview",
              "networking/request-lifecycle",
              "networking/internal-services",
              "networking/rate-limits"
            ]
          },
          {
            "group": "Scaling",
            "icon": "arrows-up-down",
            "pages": ["scaling/overview"]
          },
          {
            "group": "Observability",
            "icon": "gauge",
            "pages": ["observability/metrics", "observability/logs"]
          },
          {
            "group": "Analytics",
            "icon": "chart-line",
            "pages": ["analytics/web-analytics"]
          },
          {
            "group": "Workspaces and teams",
            "icon": "users",
            "pages": [
              "workspaces-and-teams/create-a-workspace",
              "workspaces-and-teams/manage-teams"
            ]
          },
          {
            "group": "Security",
            "icon": "shield-halved",
            "pages": [
              "security/api-keys",
              "security/two-factor-authentication"
            ]
          },
          {
            "group": "Billing",
            "icon": "receipt",
            "pages": ["billing/plans", "billing/build-minutes"]
          },
          {
            "group": "Notifications",
            "icon": "bell",
            "pages": ["notifications/overview"]
          },
          {
            "group": "Webhooks",
            "icon": "bolt",
            "pages": ["webhooks/overview", "webhooks/events"]
          },
          {
            "group": "Troubleshooting",
            "icon": "wrench",
            "pages": [
              "troubleshooting/build-failures",
              "troubleshooting/application-failed-to-respond",
              "troubleshooting/502-errors",
              "troubleshooting/dns",
              "troubleshooting/tls",
              "troubleshooting/deployment-stuck"
            ]
          },
          {
            "group": "Reference",
            "icon": "book",
            "pages": ["glossary"]
          }
        ]
      },
      {
        "tab": "Sandbox API",
        "openapi": "/api-reference/sandboxes.openapi.yaml",
        "groups": [
          {
            "group": "Discovery",
            "icon": "compass",
            "pages": [
              "api-reference/sandboxes/templates-list",
              "api-reference/sandboxes/regions-list"
            ]
          },
          {
            "group": "Sandboxes",
            "icon": "box",
            "pages": [
              "api-reference/sandboxes/create",
              "api-reference/sandboxes/list",
              "api-reference/sandboxes/get",
              "api-reference/sandboxes/destroy",
              "api-reference/sandboxes/pause",
              "api-reference/sandboxes/resume"
            ]
          },
          {
            "group": "Runtime",
            "icon": "terminal",
            "pages": [
              "api-reference/sandboxes/exec",
              "api-reference/sandboxes/code",
              "api-reference/sandboxes/upload-file",
              "api-reference/sandboxes/download-file"
            ]
          },
          {
            "group": "Observability",
            "icon": "gauge",
            "pages": ["api-reference/sandboxes/stats"]
          },
          {
            "group": "Snapshots",
            "icon": "camera",
            "pages": [
              "api-reference/sandboxes/snapshot-create",
              "api-reference/sandboxes/snapshot-list",
              "api-reference/sandboxes/snapshots-list-all",
              "api-reference/sandboxes/snapshot-delete"
            ]
          },
          {
            "group": "Volumes",
            "icon": "hard-drive",
            "pages": [
              "api-reference/volumes/create",
              "api-reference/volumes/list",
              "api-reference/volumes/get",
              "api-reference/volumes/delete"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.brimble.io"
      },
      {
        "label": "Changelog",
        "href": "https://brimble.io/changelog"
      },
      {
        "label": "Status",
        "href": "https://status.brimble.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://app.brimble.io/signup"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/brimblehq",
      "github": "https://github.com/brimblehq"
    }
  }
}
